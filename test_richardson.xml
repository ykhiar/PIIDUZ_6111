<!-- question: 46814650  -->
  <question type="multichoice">
    <name>
      <text>Comprobar que Richardson mejora el resultado</text>
    </name>
    <questiontext format="html">
      <text><![CDATA[<p>Para \(f(x)=\sin x, c=0, h=0.1\), ¿cuál de los siguientes valores es coherente con el error absoluto cometido por \(N_2(h)\),?</p>]]></text>
    </questiontext>
    <generalfeedback format="html">
      <text></text>
    </generalfeedback>
    <defaultgrade>1.0000000</defaultgrade>
    <penalty>0.3333333</penalty>
    <hidden>0</hidden>
    <idnumber></idnumber>
    <single>true</single>
    <shuffleanswers>true</shuffleanswers>
    <answernumbering>abc</answernumbering>
    <showstandardinstruction>0</showstandardinstruction>
    <correctfeedback format="html">
      <text><![CDATA[<p>Respuesta correcta</p>]]></text>
    </correctfeedback>
    <partiallycorrectfeedback format="html">
      <text><![CDATA[<p>Respuesta parcialmente correcta.</p>]]></text>
    </partiallycorrectfeedback>
    <incorrectfeedback format="html">
      <text><![CDATA[<p>Respuesta incorrecta.</p>]]></text>
    </incorrectfeedback>
    <shownumcorrect/>
    <answer fraction="0" format="html">
      <text><![CDATA[<p>\(1.7 \times 10 ^{-3}\)</p>]]></text>
      <feedback format="html">
        <text><![CDATA[<p>Este valor corresponde aproximadamente al error de \(N_1(h)\).</p>]]></text>
      </feedback>
    </answer>
    <answer fraction="100" format="html">
      <text><![CDATA[<p>\(2.1\times 10 ^{-7}\)</p>]]></text>
      <feedback format="html">
        <text><![CDATA[<p>Correcto: la extrapolación reduce el error varios órdenes.</p>]]></text>
      </feedback>
    </answer>
    <answer fraction="0" format="html">
      <text><![CDATA[<p>\(2.0 \times 10 ^{-2}\)</p>]]></text>
      <feedback format="html">
        <text><![CDATA[<p>El error es demasiado grande.</p>]]></text>
      </feedback>
    </answer>
    <answer fraction="0" format="html">
      <text><![CDATA[<p>\(1.0 \times 10 ^{-1}\)</p>]]></text>
      <feedback format="html">
        <text><![CDATA[<p>No es coherente con un método de orden 4.</p>]]></text>
      </feedback>
    </answer>
  </question>

